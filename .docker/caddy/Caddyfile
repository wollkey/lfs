{
    auto_https off
}

:8080 {
    root * /var/www/public

    encode gzip

    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    @api path /api /api/*
    handle @api {
        php_server {
            try_files index.php
        }
    }

    @dotfiles path */.*
    handle @dotfiles {
        respond 404
    }

    @php path *.php
    handle @php {
        respond 404
    }

    handle {
        try_files {path} /index.html
        file_server
    }

    log {
        output stdout
        format json
    }
}
